// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Quote Submissions from contact form
model QuoteSubmission {
  id             String   @id @default(cuid())
  fullName       String
  email          String
  phone          String
  companyName    String?
  companyUrl     String?
  services       String[]
  projectDetails String?
  hearAbout      String?
  status         String   @default("new")
  submittedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Projects
model Project {
  id           String   @id @default(cuid())
  projectName  String
  description  String?
  clientName   String
  clientEmail  String
  clientPhone  String
  companyName  String?
  services     String[]
  status       String   @default("discovery")
  priority     String   @default("medium")
  progress     Int      @default(0)
  budget       Float    @default(0)
  spent        Float    @default(0)
  startDate    DateTime?
  deadline     DateTime?
  teamMembers  String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks        Task[]
  milestones   Milestone[]
  notes        Note[]
  activityLogs ActivityLog[]
}

// Tasks
model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  dueDate     DateTime?
  assignee    String?
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Milestones
model Milestone {
  id        String   @id @default(cuid())
  title     String
  dueDate   DateTime?
  completed Boolean  @default(false)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Notes
model Note {
  id        String   @id @default(cuid())
  content   String
  author    String   @default("Admin")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// Activity Logs
model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  user      String   @default("Admin")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
}

// Admin Login Attempts (Rate Limiting)
model LoginAttempt {
  id        String   @id @default(cuid())
  ipAddress String
  email     String
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ipAddress, createdAt])
}

// 2FA Verification Codes
model TwoFactorCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// Job Positions / Careers
model JobPosition {
  id            String   @id @default(cuid())
  title         String
  department    String
  location      String
  type          String   @default("Full-time") // Full-time, Part-time, Contract, Remote
  experience    String   // e.g., "2-4 years", "5+ years"
  salary        String?  // Optional salary range
  description   String
  requirements  String[] // List of requirements
  responsibilities String[] // List of responsibilities
  benefits      String[] // List of benefits
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Client quotations / offer letters (admin generator)
model ClientQuotation {
  id               String   @id @default(cuid())
  quoteNumber      String   @unique
  customerName     String
  companyName      String?
  quoteDate        DateTime @default(now())
  projectTitle     String
  projectSubtitle  String?
  introText        String?
  projectType      String?
  technology       String?
  totalPages       String?
  timeline         String?
  scopeSections    Json     @default("[]")
  includes         String[]
  optionalServices Json     @default("[]")
  showSocialMedia  Boolean  @default(true)
  socialMediaFee   Float    @default(600)
  socialIncludes   String[]
  baseAmount       Float
  discountPercent  Float    @default(10)
  hstPercent       Float    @default(13)
  depositPercent   Float    @default(50)
  terms            String[]
  status           String   @default("draft")
  shareToken       String?  @unique
  shareExpiresAt   DateTime?
  clientSelections Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── SEO Panel ───────────────────────────────────────────────

model SeoSession {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model SeoKeyword {
  id           String   @id @default(cuid())
  keyword      String
  targetUrl    String?
  currentRank  Int?
  previousRank Int?
  bestRank     Int?
  searchVolume Int?
  difficulty   Int?
  priority     String   @default("medium")
  status       String   @default("tracking")
  country      String   @default("CA")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rankHistory SeoRankHistory[]
}

model SeoRankHistory {
  id         String     @id @default(cuid())
  keywordId  String
  keyword    SeoKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  rank       Int
  recordedAt DateTime   @default(now())

  @@index([keywordId])
}

model SeoPage {
  id              String    @id @default(cuid())
  path            String    @unique
  title           String?
  metaDescription String?
  h1              String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  focusKeyword    String?
  seoScore        Int       @default(0)
  indexStatus     String    @default("index")
  status          String    @default("needs_review")
  lastAuditedAt   DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SeoBacklink {
  id         String    @id @default(cuid())
  sourceUrl  String
  targetUrl  String
  anchorText String?
  domainAuth Int?
  linkType   String    @default("dofollow")
  status     String    @default("active")
  acquiredAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SeoTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  category    String    @default("general")
  priority    String    @default("medium")
  status      String    @default("pending")
  dueDate     DateTime?
  assignee    String    @default("SEO Expert")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SeoAudit {
  id              String   @id @default(cuid())
  title           String
  auditType       String   @default("full")
  score           Int      @default(0)
  findings        String?
  recommendations String?
  status          String   @default("completed")
  auditedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SeoCompetitor {
  id          String   @id @default(cuid())
  domain      String
  name        String?
  domainAuth  Int?
  topKeywords String[]
  strengths   String?
  weaknesses  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeoTechnicalIssue {
  id          String    @id @default(cuid())
  title       String
  description String?
  severity    String    @default("medium")
  category    String
  status      String    @default("open")
  affectedUrl String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SeoContentBrief {
  id            String    @id @default(cuid())
  title         String
  targetUrl     String?
  targetKeyword String?
  wordCount     Int?
  status        String    @default("draft")
  brief         String?
  outline       String?
  notes         String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SeoReport {
  id         String   @id @default(cuid())
  title      String
  period     String
  reportType String   @default("monthly")
  summary    String?
  metrics    String?
  highlights String?
  challenges String?
  nextSteps  String?
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SeoSettings {
  id                   String    @id @default("default")
  siteUrl              String    @default("https://vyntechsolutions.ca")
  gscProperty          String?
  gaPropertyId         String?
  googleVerification   String?
  bingVerification     String?
  defaultTitle         String?
  defaultDescription   String?
  robotsTxtNotes       String?
  sitemapLastSubmitted DateTime?
  targetCountry        String    @default("CA")
  targetCities         String[]
  monthlyTrafficGoal   Int?
  monthlyLeadsGoal     Int?
  notes                String?
  updatedAt            DateTime  @updatedAt
}

model SeoActivityLog {
  id        String   @id @default(cuid())
  action    String
  module    String
  details   String?
  user      String   @default("SEO Expert")
  createdAt DateTime @default(now())

  @@index([createdAt])
}
