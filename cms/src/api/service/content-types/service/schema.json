{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "heroImage": {
      "type": "string"
    },
    "overview": {
      "type": "richtext"
    },
    "overviewTagline": {
      "type": "text"
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "shared.named-item"
    },
    "technologies": {
      "type": "json"
    },
    "processHeading": {
      "type": "string"
    },
    "processDescription": {
      "type": "text"
    },
    "process": {
      "type": "component",
      "repeatable": true,
      "component": "shared.process-step"
    },
    "stats": {
      "type": "component",
      "repeatable": true,
      "component": "shared.stat"
    },
    "caseStudies": {
      "type": "component",
      "repeatable": true,
      "component": "shared.case-study"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "whyChooseUsHeading": {
      "type": "string"
    },
    "whyChooseUsIntro": {
      "type": "text"
    },
    "whyChooseUsSubHeading": {
      "type": "string"
    },
    "whyChooseUsSubText": {
      "type": "text"
    },
    "whyChooseUsCards": {
      "type": "component",
      "repeatable": true,
      "component": "sections.value-card"
    },
    "deliveryHeading": {
      "type": "string"
    },
    "deliveryDescription": {
      "type": "text"
    },
    "deliverySteps": {
      "type": "component",
      "repeatable": true,
      "component": "sections.delivery-step"
    },
    "faqs": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq"
    }
  }
}
