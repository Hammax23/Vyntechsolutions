{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "subtitle": { "type": "string" },
    "description": { "type": "text" },
    "heroImage": { "type": "string" },
    "overview": { "type": "richtext" },
    "features": { "type": "component", "repeatable": true, "component": "shared.named-item" },
    "technologies": { "type": "json" },
    "process": { "type": "component", "repeatable": true, "component": "shared.process-step" },
    "stats": { "type": "component", "repeatable": true, "component": "shared.stat" },
    "caseStudies": { "type": "component", "repeatable": true, "component": "shared.case-study" },
    "seo": { "type": "component", "repeatable": false, "component": "shared.seo" },
    "order": { "type": "integer", "default": 0 }
  }
}
